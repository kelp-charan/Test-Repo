{
  "name": "kelp-frontend",
  "version": "0.0.2",
  "license": "private",
  "sideEffects": false,
  "scripts": {
    "build_shared_lib": "pnpm --prefix ../shared-library run build",
    "dev_shared_lib": "pnpm --prefix ../shared-library run dev",
    "start": "pnpm run build_shared_lib && nx serve",
    "dev": "nx serve main-app --open --devRemotes=sourcing,deals,portfolio,contacts,ic-notes,admin,investors,ext-investor",
    "dev:main": "nx serve main-app",
    "dev_all": "concurrently \"pnpm run dev_shared_lib\"  \"pnpm run dev\"",
    "build": "pnpm run build_shared_lib && nx build main-app && cp -r ./libs/styles/src/assets/images/icons/clients ./dist/apps/main-app",
    "lint": "nx run-many --all --target=lint",
    "start:storybook": "pnpm run dev_shared_lib && nx run common-uikit:storybook",
    "build:storybook": "pnpm run build_shared_lib && export NODE_OPTIONS=--max_old_space_size=4096 && nx run common-uikit:build-storybook",
    "postinstall": "mkdir -p .nx",
    "update-remotes": "node apps/main-app/update-remotes.js",
    "serve:remotes": "node serve-with-remotes.js"
  },
  "private": true,
