{
  "name": "server",
  "version": "0.0.0",
  "license": "private",
  "scripts": {
    "build_shared_lib": "pnpm --prefix ../shared-library run build",
    "dev_shared_lib": "pnpm --prefix ../shared-library run dev",
    "start": "concurrently \"pnpm run dev_shared_lib\" \"nx run-many --target=serve --maxParallel=7 --projects=core,sourcing,portfolio,contacts,ic-notes,deals,enterprise-search,notification,investors,analytics\"",
    "build": "pnpm run build_shared_lib && nx clear-cache && nx run-many --target=build --projects=core,sourcing,contacts,ic-notes,deals,enterprise-search,portfolio,notification,investors,analytics --skip-nx-cache",
    "postinstall": "pnpm run build_shared_lib",
    "test:sourcing": "test/setup-test-db.sh sourcing && nx test sourcing --coverage --verbose --skip-nx-cache ${TEST_FILE:+--testFile $TEST_FILE}",
    "test:deals": "test/setup-test-db.sh deals && nx test deals --coverage --verbose --skip-nx-cache ${TEST_FILE:+--testFile $TEST_FILE}",
    "test:deals-ic-notes": "test/setup-test-db.sh deals && nx run-many --target=test --projects=deals,ic-notes --coverage --verbose --skip-nx-cache --runInBand ${TEST_FILE:+--testFile $TEST_FILE}",
    "test:portfolio": "test/setup-test-db.sh portfolio && TZ=UTC nx test portfolio --coverage --verbose --skip-nx-cache --runInBand ${TEST_FILE:+--testFile $TEST_FILE}",
    "test:contacts": "test/setup-test-db.sh contacts && TZ=UTC nx test contacts --coverage --verbose --skip-nx-cache --runInBand ${TEST_FILE:+--testFile $TEST_FILE}",
    "test:investors": "test/setup-test-db.sh investors && nx test investors --coverage --verbose --skip-nx-cache ${TEST_FILE:+--testFile $TEST_FILE}",
    "test:common": "test/setup-test-db.sh core && nx test common --coverage --verbose --skip-nx-cache  ${TEST_FILE:+--testFile $TEST_FILE}",
    "test:core": "test/setup-test-db.sh core && TZ=UTC nx test core --coverage --verbose --skip-nx-cache ${TEST_FILE:+--testFile $TEST_FILE}",
    "test-coverage": "test/setup-test-db.sh && TZ=UTC nx run-many --target=test --coverage --verbose --skip-nx-cache --runInBand",
    "test": "test/setup-test-db.sh && TZ=UTC test/run-test.sh",
    "lint": "nx run-many --target=lint --all",
    "ci": "pnpm run lint && pnpm run test",
    "migrations:core": "cd apps/core && pg-migrate src/app/migrations",
    "migrations:sourcing": "cd apps/sourcing && pg-migrate src/app/migrations",
    "migrations:deals": "cd apps/deals && pg-migrate src/app/migrations",
    "migrations:portfolio": "cd apps/portfolio && pg-migrate src/app/migrations",
    "migrations:contacts": "cd apps/contacts && pg-migrate src/app/migrations",
    "migrations:ic-notes": "cd apps/ic-notes && pg-migrate src/app/migrations",
    "migrations:investors": "cd apps/investors && pg-migrate src/app/migrations",
    "migrations:analytics": "cd apps/analytics && pg-migrate src/app/migrations",
    "migrations": "pnpm run \"/^migrations:.*/\"",
    "test-only": "test/setup-test-db.sh && nx test --watch --testFile $npm_package_config_modulename $npm_package_config_filename",
    "obfuscate-and-encrypt": "node ./kavach/obfuscate-and-encrypt.js $encryption_key"
  },
  "private": true,
